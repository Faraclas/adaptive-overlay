# Build environment for media-sound packages from adaptive-overlay
#
# Builds on top of the general-purpose testenv image. Adds Portage
# configuration and dependencies needed to build audio packages:
#   media-sound/carla       - audio plugin host (with Wine bridges)
#   media-sound/yabridge    - Windows VST/VST3/CLAP bridge via Wine
#   media-sound/surgext     - Surge XT synthesizer
#   media-sound/bitwig-studio - DAW (binary, needs multilib X libs)
#   media-sound/amp-locker  - guitar amp simulator plugin
#   media-sound/drum-locker - drum machine plugin
#
# This image provides:
#   - Wine with abi_x86_32 (not wow64) for winegcc 32-bit support
#   - MinGW cross-toolchain for Windows PE binaries
#   - JACK, ALSA, PulseAudio, PipeWire audio stack
#   - Multilib X11/XCB libraries for Bitwig and yabridge
#   - FluidSynth, libsndfile, LADSPA/LV2 plugin support
#   - Qt6 and GTK3 for plugin UIs
#   - Rust toolchain for yabridge
#
# Note on wow64 vs abi_x86_32:
#   Carla wine32 build target uses winegcc -m32 to produce a
#   32-bit Linux .dll.so (jackbridge-wine32.dll.so). This requires
#   Wine 32-bit import libraries (libadvapi32, libuser32, etc.)
#   which are only installed when abi_x86_32 is enabled. The wow64
#   USE flag is mutually exclusive with abi_x86_32 on x86_64:
#     REQUIRED_USE: wow64? ( !arm64? ( !abi_x86_32 ) )
#   So we explicitly disable wow64 and enable abi_x86_32.
#
# Build from repo root:
#   podman build -t adaptive-overlay-testenv-audio:local \
#       -f containers/testenv-audio/Containerfile .
#
# Note: The dependency lists were determined by querying the build
# host with eix and matching installed USE flags. If ebuild deps
# change, rebuild with --no-cache and re-verify.

FROM ghcr.io/faraclas/adaptive-overlay/testenv:latest

# -------------------------------------------------------------------
# Portage: disable sandbox features that fail in rootless containers
# -------------------------------------------------------------------
RUN mkdir -p /etc/portage && \
    echo 'FEATURES="-ipc-sandbox -network-sandbox -pid-sandbox -usersandbox"' \
    >> /etc/portage/make.conf

# -------------------------------------------------------------------
# Portage: USE and ABI flags
#
# Mirrors the build host package.use for audio packages. Key
# decisions:
#   - Wine: abi_x86_32, -wow64 (for winegcc 32-bit import libs)
#   - Multilib X libs: abi_x86_32 (for Bitwig and yabridge)
#   - FluidSynth: jack, ladspa
#   - PipeWire: jack-sdk (for Bitwig)
# -------------------------------------------------------------------
RUN mkdir -p /etc/portage/package.use && \
    cat > /etc/portage/package.use/audio <<'EOF'
# === Wine and MinGW ===
# xcomposite flag dropped in wine-staging-11
app-emulation/wine-staging alsa dbus ffmpeg fontconfig gstreamer mono opengl pulseaudio ssl strip truetype udev unwind vulkan wayland x xcomposite xinerama abi_x86_32 -wow64
dev-util/mingw64-toolchain abi_x86_32

# === Audio stack ===
media-sound/fluidsynth jack ladspa
media-video/pipewire jack-sdk

# === Multilib X11/XCB libs (Bitwig, yabridge) ===
x11-libs/libX11 abi_x86_32
x11-libs/libxcb abi_x86_32
x11-libs/xcb-util-wm abi_x86_32
x11-libs/xcb-util abi_x86_32
x11-libs/libxkbcommon abi_x86_32 X
x11-libs/libXau abi_x86_32
x11-libs/libXdmcp abi_x86_32
x11-libs/pixman abi_x86_32

# === Wine multilib dep chain (abi_x86_32) ===
>=media-libs/gst-plugins-base-1.24.11-r1 abi_x86_32
>=media-libs/gstreamer-1.24.11 abi_x86_32
>=sys-libs/libunwind-1.8.2-r1 abi_x86_32
>=media-plugins/gst-plugins-meta-1.24.11 abi_x86_32
>=media-libs/gst-plugins-good-1.24.11 abi_x86_32
>=media-plugins/gst-plugins-a52dec-1.24.11 abi_x86_32
>=media-plugins/gst-plugins-faad-1.24.11 abi_x86_32
>=media-plugins/gst-plugins-dts-1.24.11 abi_x86_32
>=media-libs/gst-plugins-ugly-1.24.11 abi_x86_32
>=media-plugins/gst-plugins-dvdread-1.24.11 abi_x86_32
>=media-plugins/gst-plugins-mpeg2dec-1.24.11 abi_x86_32
>=media-plugins/gst-plugins-resindvd-1.24.11 abi_x86_32
>=media-plugins/gst-plugins-flac-1.24.11 abi_x86_32
>=media-plugins/gst-plugins-mpg123-1.24.11 abi_x86_32
>=media-plugins/gst-plugins-pulse-1.24.11 abi_x86_32
>=media-libs/gst-plugins-bad-1.24.11 abi_x86_32
>=media-plugins/gst-plugins-x264-1.24.11 abi_x86_32
>=media-libs/x264-0.0.20240513 abi_x86_32
>=dev-lang/orc-0.4.41 abi_x86_32
>=media-libs/libdvdnav-6.1.1 abi_x86_32
>=media-libs/libdvdread-6.1.3 abi_x86_32
>=media-libs/libdvdcss-1.4.3 abi_x86_32
>=media-libs/libmpeg2-0.5.1-r3 abi_x86_32
>=media-libs/libdca-0.0.7 abi_x86_32
>=media-libs/faad2-2.11.2 abi_x86_32
>=media-libs/a52dec-0.7.4-r9 abi_x86_32
>=media-libs/libtheora-1.2.0-r1 abi_x86_32
>=x11-libs/libXv-1.0.13 abi_x86_32
>=media-libs/graphene-1.10.8-r1 abi_x86_32
>=media-plugins/gst-plugins-cdparanoia-1.24.11 abi_x86_32
>=media-sound/cdparanoia-3.10.2-r8 abi_x86_32
>=media-video/ffmpeg-7.0 abi_x86_32
>=media-libs/opencore-amr-0.1.6 abi_x86_32
>=media-libs/vo-amrwbenc-0.1.3 abi_x86_32
>=media-libs/dav1d-1.5.0 abi_x86_32
>=media-libs/libjxl-0.11.1 abi_x86_32
>=media-libs/libass-0.17.4 abi_x86_32
>=media-sound/sndio-1.10.0 abi_x86_32
>=media-libs/xvid-1.3.7-r2 abi_x86_32
>=dev-libs/libbsd-0.11.8 abi_x86_32
>=app-crypt/libmd-1.1.0 abi_x86_32
>=app-arch/brotli-1.1.0 abi_x86_32
>=dev-cpp/highway-1.3.0 abi_x86_32
>=media-libs/giflib-5.2.2 abi_x86_32
>=virtual/jack-2 abi_x86_32
EOF

# -------------------------------------------------------------------
# Portage: accept ~amd64 keywords
# -------------------------------------------------------------------
RUN mkdir -p /etc/portage/package.accept_keywords && \
    cat > /etc/portage/package.accept_keywords/audio <<'EOF'
# wine-staging is keyworded ~amd64
app-emulation/wine-staging ~amd64
# yabridge is keyworded ~amd64
media-sound/yabridge ~amd64
# surgext, amp-locker, drum-locker are keyworded ~amd64
media-sound/surgext ~amd64
media-sound/amp-locker ~amd64
media-sound/drum-locker ~amd64
EOF

# -------------------------------------------------------------------
# Install the full audio build dependency stack
#
# Covers build deps for all media-sound packages in the overlay.
# Combined into one emerge for image layer efficiency.
# -------------------------------------------------------------------
RUN emerge --oneshot --quiet-build \
    app-emulation/wine-staging \
    dev-util/mingw64-toolchain \
    virtual/jack \
    media-libs/alsa-lib \
    media-libs/libpulse \
    media-video/pipewire \
    media-sound/fluidsynth \
    media-libs/libsndfile \
    media-libs/ladspa-sdk \
    media-libs/lv2 \
    x11-libs/gtk+:3 \
    x11-libs/libX11 \
    x11-libs/libxcb \
    x11-libs/xcb-util-wm \
    x11-libs/xcb-util \
    x11-libs/libxkbcommon \
    x11-libs/libXau \
    x11-libs/libXdmcp \
    x11-libs/pixman \
    x11-libs/libXcursor \
    x11-libs/libXrandr \
    x11-libs/libXinerama \
    x11-libs/libXext \
    x11-libs/libXfixes \
    x11-libs/libXrender \
    x11-libs/libXv \
    x11-libs/cairo \
    x11-libs/xcb-util-cursor \
    x11-libs/xcb-util-keysyms \
    dev-python/pyqt5 \
    dev-python/rdflib \
    media-libs/freetype \
    media-libs/fontconfig \
    net-misc/curl \
    net-libs/webkit-gtk:4.1 \
    dev-build/meson \
    dev-lang/rust-bin \
    app-arch/unzip \
    dev-util/patchelf \
    media-libs/libpng \
    media-video/ffmpeg \
    sys-libs/zlib \
    dev-libs/expat \
    app-arch/libarchive \
    media-libs/liblrdf \
    media-libs/portmidi
