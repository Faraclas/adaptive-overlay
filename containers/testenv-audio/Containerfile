# Build environment for media-sound packages from adaptive-overlay
#
# Builds on top of the general-purpose testenv image. Adds Portage
# configuration and dependencies needed to build audio packages:
#   media-sound/carla       - audio plugin host (with Wine bridges)
#   media-sound/yabridge    - Windows VST/VST3/CLAP bridge via Wine
#   media-sound/surgext     - Surge XT synthesizer
#   media-sound/bitwig-studio - DAW (binary, needs multilib X libs)
#   media-sound/amp-locker  - guitar amp simulator plugin
#   media-sound/drum-locker - drum machine plugin
#
# This image provides:
#   - Wine with abi_x86_32 (not wow64) for winegcc 32-bit support
#   - MinGW cross-toolchain for Windows PE binaries
#   - JACK, ALSA, PulseAudio audio stack
#   - Multilib X11/XCB libraries for Bitwig and yabridge
#   - FluidSynth, libsndfile, LADSPA/LV2 plugin support
#   - GTK3 for plugin UIs
#   - Rust toolchain for yabridge
#
# Note on wow64 vs abi_x86_32:
#   Carla wine32 build target uses winegcc -m32 to produce a
#   32-bit Linux .dll.so (jackbridge-wine32.dll.so). This requires
#   Wine 32-bit import libraries (libadvapi32, libuser32, etc.)
#   which are only installed when abi_x86_32 is enabled. The wow64
#   USE flag is mutually exclusive with abi_x86_32 on x86_64:
#     REQUIRED_USE: wow64? ( !arm64? ( !abi_x86_32 ) )
#   So we explicitly disable wow64 and enable abi_x86_32.
#
# Build from repo root:
#   podman build -t adaptive-overlay-testenv-audio:local \
#       -f containers/testenv-audio/Containerfile .

FROM ghcr.io/faraclas/adaptive-overlay/testenv:latest

# -------------------------------------------------------------------
# Portage: disable sandbox features that fail in rootless containers
# -------------------------------------------------------------------
RUN mkdir -p /etc/portage && \
    echo 'FEATURES="-ipc-sandbox -network-sandbox -pid-sandbox -usersandbox"' \
    >> /etc/portage/make.conf

# -------------------------------------------------------------------
# Portage: USE and ABI flags
#
# Organized by purpose. The full abi_x86_32 transitive dep chain
# was derived from emerge dependency resolution output for
# wine-staging[abi_x86_32] and manually curated.
# -------------------------------------------------------------------
RUN mkdir -p /etc/portage/package.use && \
    cat > /etc/portage/package.use/audio <<'EOF'
# === Wine and MinGW (top-level) ===
app-emulation/wine-staging abi_x86_32 -wow64 alsa dbus ffmpeg fontconfig gstreamer opengl pulseaudio ssl truetype udev unwind vulkan wayland x xinerama
dev-util/mingw64-toolchain abi_x86_32

# === Audio stack ===
media-sound/fluidsynth jack ladspa
net-libs/webkit-gtk X

# === Multilib X11/XCB ===
x11-libs/libX11 abi_x86_32
x11-libs/libxcb abi_x86_32
x11-libs/xcb-util abi_x86_32
x11-libs/xcb-util-wm abi_x86_32
x11-libs/xcb-util-keysyms abi_x86_32
x11-libs/libxkbcommon abi_x86_32 X
x11-libs/libXau abi_x86_32
x11-libs/libXdmcp abi_x86_32
x11-libs/libXv abi_x86_32
x11-libs/libxshmfence abi_x86_32
x11-libs/libXcomposite abi_x86_32
x11-libs/libXcursor abi_x86_32
x11-libs/libXext abi_x86_32
x11-libs/libXfixes abi_x86_32
x11-libs/libXi abi_x86_32
x11-libs/libXinerama abi_x86_32
x11-libs/libXrandr abi_x86_32
x11-libs/libXrender abi_x86_32
x11-libs/libXxf86vm abi_x86_32
x11-libs/libdrm abi_x86_32
x11-libs/libpciaccess abi_x86_32
x11-libs/pixman abi_x86_32
x11-libs/cairo abi_x86_32 X
x11-libs/pango abi_x86_32
virtual/jack abi_x86_32
virtual/opengl abi_x86_32

# === Wine abi_x86_32 transitive dep chain ===
#
# wine-staging[abi_x86_32] pulls gstreamer, ffmpeg, mesa,
# pulseaudio and their full dependency trees in 32-bit.
# Every entry below was identified from emerge output.

# -- GStreamer --
media-libs/gstreamer abi_x86_32
media-libs/gst-plugins-base abi_x86_32 opengl
media-libs/gst-plugins-good abi_x86_32
media-libs/gst-plugins-bad abi_x86_32
media-libs/gst-plugins-ugly abi_x86_32
media-plugins/gst-plugins-meta abi_x86_32
media-plugins/gst-plugins-a52dec abi_x86_32
media-plugins/gst-plugins-cdparanoia abi_x86_32
media-plugins/gst-plugins-dts abi_x86_32
media-plugins/gst-plugins-dvdread abi_x86_32
media-plugins/gst-plugins-faad abi_x86_32
media-plugins/gst-plugins-flac abi_x86_32
media-plugins/gst-plugins-mpeg2dec abi_x86_32
media-plugins/gst-plugins-mpg123 abi_x86_32
media-plugins/gst-plugins-pulse abi_x86_32
media-plugins/gst-plugins-resindvd abi_x86_32
media-plugins/gst-plugins-x264 abi_x86_32
dev-lang/orc abi_x86_32

# -- FFmpeg / media codecs --
media-video/ffmpeg abi_x86_32
media-libs/x264 abi_x86_32
media-libs/dav1d abi_x86_32
media-libs/libjxl abi_x86_32
media-libs/libass abi_x86_32
media-libs/xvid abi_x86_32
media-libs/opencore-amr abi_x86_32
media-libs/vo-amrwbenc abi_x86_32
media-libs/faad2 abi_x86_32
media-libs/a52dec abi_x86_32
media-libs/libtheora abi_x86_32
media-libs/libdca abi_x86_32
media-libs/libmpeg2 abi_x86_32
media-libs/graphene abi_x86_32
media-libs/flac abi_x86_32
media-libs/opus abi_x86_32
media-libs/giflib abi_x86_32
media-libs/libsndfile abi_x86_32
media-libs/libogg abi_x86_32
media-libs/libvorbis abi_x86_32
media-libs/libjpeg-turbo abi_x86_32
media-libs/libpng abi_x86_32
media-sound/cdparanoia abi_x86_32
media-sound/sndio abi_x86_32
media-sound/lame abi_x86_32
media-sound/mpg123-base abi_x86_32

# -- DVD / optical --
media-libs/libdvdnav abi_x86_32
media-libs/libdvdread abi_x86_32
media-libs/libdvdcss abi_x86_32

# -- Mesa / graphics --
media-libs/mesa abi_x86_32
media-libs/libglvnd abi_x86_32 X
llvm-core/llvm abi_x86_32
dev-util/spirv-tools abi_x86_32

# -- Vulkan --
media-libs/vulkan-loader abi_x86_32 wayland X
media-libs/libsdl2 abi_x86_32

# -- PulseAudio --
media-libs/libpulse abi_x86_32 X
media-plugins/alsa-plugins pulseaudio
