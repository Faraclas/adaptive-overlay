# -------------------------------------------------------------------
# Portage: accept ~amd64 keywords
# -------------------------------------------------------------------
RUN mkdir -p /etc/portage/package.accept_keywords && \
    cat > /etc/portage/package.accept_keywords/audio <<'EOF'
app-emulation/wine-staging ~amd64
media-sound/yabridge ~amd64
media-sound/surgext ~amd64
media-sound/amp-locker ~amd64
media-sound/drum-locker ~amd64
EOF

# -------------------------------------------------------------------
# Layer 1: Core libs, X11, audio stack, and light tools
#
# Foundation layer — small-to-medium packages that rarely change.
# Installing these first means later layers only compile what
# they actually add, and this layer stays cached across rebuilds.
# -------------------------------------------------------------------
RUN emerge --oneshot --quiet-build \
    sys-libs/zlib \
    dev-libs/expat \
    dev-libs/glib \
    media-libs/libpng \
    media-libs/freetype \
    media-libs/fontconfig \
    x11-libs/libXau \
    x11-libs/libXdmcp \
    x11-libs/libX11 \
    x11-libs/libxcb \
    x11-libs/xcb-util \
    x11-libs/xcb-util-wm \
    x11-libs/xcb-util-keysyms \
    x11-libs/xcb-util-cursor \
    x11-libs/libxkbcommon \
    x11-libs/libXext \
    x11-libs/libXfixes \
    x11-libs/libXrender \
    x11-libs/libXrandr \
    x11-libs/libXcursor \
    x11-libs/libXinerama \
    x11-libs/libXv \
    x11-libs/pixman \
    x11-libs/cairo \
    x11-libs/gtk+:3 \
    virtual/jack \
    media-libs/alsa-lib \
    media-libs/libpulse \
    media-sound/fluidsynth \
    media-libs/libsndfile \
    media-libs/ladspa-sdk \
    media-libs/lv2 \
    media-libs/liblrdf \
    media-libs/portmidi \
    net-misc/curl \
    dev-build/meson \
    dev-lang/rust-bin \
    app-arch/unzip \
    app-arch/libarchive \
    dev-util/patchelf

# -------------------------------------------------------------------
# Layer 2: FFmpeg and multimedia codecs
#
# Medium-heavy layer. FFmpeg pulls in many codec libraries via
# USE flags. Separating it means codec updates don't force a
# Wine or WebKit rebuild.
# -------------------------------------------------------------------
RUN emerge --oneshot --quiet-build \
    media-video/ffmpeg

# -------------------------------------------------------------------
# Layer 3: PyQt5, WebKit-GTK, and Python tools
#
# Heavy layer — WebKit and Qt5 are large builds. Cached
# independently so Wine rebuilds don't re-trigger them.
# -------------------------------------------------------------------
RUN emerge --oneshot --quiet-build \
    dev-python/pyqt5 \
    dev-python/rdflib \
    net-libs/webkit-gtk:4.1

# -------------------------------------------------------------------
# Layer 4: Wine + MinGW cross-toolchain
#
# Heaviest layer. With all dependencies already installed in
# layers 1–3, this only compiles Wine and MinGW themselves.
# Gets its own layer so base-image updates that don't affect
# Wine's deps result in a cache hit here.
# -------------------------------------------------------------------
RUN emerge --oneshot --quiet-build \
    app-emulation/wine-staging \
    dev-util/mingw64-toolchain
