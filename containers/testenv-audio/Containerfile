# -- JACK --
media-sound/jack2 abi_x86_32

# -- Fonts / rendering --
media-libs/freetype abi_x86_32 harfbuzz
media-libs/fontconfig abi_x86_32
media-libs/harfbuzz abi_x86_32 icu
media-gfx/graphite2 abi_x86_32

# -- Core system libs --
sys-libs/libunwind abi_x86_32
sys-libs/zlib abi_x86_32
sys-libs/ncurses abi_x86_32
sys-libs/readline abi_x86_32
sys-libs/gdbm abi_x86_32
sys-libs/libcap abi_x86_32
sys-libs/pam abi_x86_32
sys-apps/systemd-utils abi_x86_32
sys-apps/dbus abi_x86_32
sys-apps/util-linux abi_x86_32
dev-libs/libpcre2 abi_x86_32
dev-libs/glib abi_x86_32
dev-libs/expat abi_x86_32
dev-libs/elfutils abi_x86_32
dev-libs/libbsd abi_x86_32
dev-libs/wayland abi_x86_32
dev-libs/libxml2 abi_x86_32
dev-libs/libffi abi_x86_32
dev-libs/icu abi_x86_32
dev-libs/nettle abi_x86_32
dev-libs/libtasn1 abi_x86_32
dev-libs/libunistring abi_x86_32
dev-libs/lzo abi_x86_32
dev-libs/isl abi_x86_32
dev-libs/fribidi abi_x86_32
dev-libs/gmp abi_x86_32
dev-cpp/highway abi_x86_32
app-crypt/libmd abi_x86_32
app-arch/brotli abi_x86_32
app-arch/bzip2 abi_x86_32
app-arch/xz-utils abi_x86_32
app-arch/zstd abi_x86_32
app-text/xmlto text
net-libs/gnutls abi_x86_32
net-libs/libasyncns abi_x86_32
net-dns/libidn2 abi_x86_32
virtual/libelf abi_x86_32
virtual/libiconv abi_x86_32
virtual/libintl abi_x86_32
virtual/libudev abi_x86_32
virtual/zlib abi_x86_32
EOF

# -------------------------------------------------------------------
# Portage: accept ~amd64 keywords
# -------------------------------------------------------------------
RUN mkdir -p /etc/portage/package.accept_keywords && \
    cat > /etc/portage/package.accept_keywords/audio <<'EOF'
app-emulation/wine-staging ~amd64
media-sound/yabridge ~amd64
media-sound/surgext ~amd64
media-sound/amp-locker ~amd64
media-sound/drum-locker ~amd64
EOF

# -------------------------------------------------------------------
# Install the full audio build dependency stack
# -------------------------------------------------------------------
RUN emerge --oneshot --quiet-build \
    app-emulation/wine-staging \
    dev-util/mingw64-toolchain \
    virtual/jack \
    media-libs/alsa-lib \
    media-libs/libpulse \
    media-sound/fluidsynth \
    media-libs/libsndfile \
    media-libs/ladspa-sdk \
    media-libs/lv2 \
    x11-libs/gtk+:3 \
    x11-libs/libX11 \
    x11-libs/libxcb \
    x11-libs/xcb-util-wm \
    x11-libs/xcb-util \
    x11-libs/libxkbcommon \
    x11-libs/libXau \
    x11-libs/libXdmcp \
    x11-libs/pixman \
    x11-libs/libXcursor \
    x11-libs/libXrandr \
    x11-libs/libXinerama \
    x11-libs/libXext \
    x11-libs/libXfixes \
    x11-libs/libXrender \
    x11-libs/libXv \
    x11-libs/cairo \
    x11-libs/xcb-util-cursor \
    x11-libs/xcb-util-keysyms \
    dev-python/pyqt5 \
    dev-python/rdflib \
    media-libs/freetype \
    media-libs/fontconfig \
    net-misc/curl \
    net-libs/webkit-gtk:4.1 \
    dev-build/meson \
    dev-lang/rust-bin \
    app-arch/unzip \
    dev-util/patchelf \
    media-libs/libpng \
    media-video/ffmpeg \
    sys-libs/zlib \
    dev-libs/expat \
    app-arch/libarchive \
    media-libs/liblrdf \
    media-libs/portmidi
