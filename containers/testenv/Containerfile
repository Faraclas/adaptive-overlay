# Stage 1: portage tree snapshot
FROM docker.io/gentoo/portage:latest AS portage

# Stage 2: our test environment
#
# Use the official desktop-systemd stage3 which ships with:
#   - systemd (not openrc)
#   - default/linux/amd64/23.0/desktop/systemd profile
#   - Desktop dependencies pre-installed
#
# This avoids the painful openrc→systemd migration that the
# generic stage3:latest required (circular deps, blockers).
FROM docker.io/gentoo/stage3:amd64-desktop-systemd

# Copy the portage tree from the portage image
COPY --from=portage /var/db/repos/gentoo /var/db/repos/gentoo

# Disable sandbox features that fail in rootless containers
RUN mkdir -p /etc/portage && \
    printf 'FEATURES="-ipc-sandbox -network-sandbox -pid-sandbox -usersandbox"\n' \
    >> /etc/portage/make.conf

# Install overlay tooling
RUN emerge --oneshot --quiet-build dev-util/pkgcheck dev-util/pkgdev

# Create the overlay mount point
RUN mkdir -p /var/db/repos/adaptive-overlay

# Tell portage about both repos.
# When /etc/portage/repos.conf/ exists as a directory, portage ignores the
# system default at /usr/share/portage/config/repos.conf entirely, so we
# must declare the gentoo repo here explicitly alongside our overlay.
RUN mkdir -p /etc/portage/repos.conf && \
    printf '[DEFAULT]\nmain-repo = gentoo\n\n[gentoo]\nlocation = /var/db/repos/gentoo\nauto-sync = no\n' \
    > /etc/portage/repos.conf/gentoo.conf && \
    printf '[adaptive-overlay]\nlocation = /var/db/repos/adaptive-overlay\nauto-sync = no\n' \
    > /etc/portage/repos.conf/adaptive-overlay.conf

# Bake in overlay metadata and profiles so portage recognises the overlay
COPY metadata/ /var/db/repos/adaptive-overlay/metadata/
COPY profiles/ /var/db/repos/adaptive-overlay/profiles/
