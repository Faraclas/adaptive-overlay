# Stage 1: Build environment for app-editors/zed from adaptive-overlay
#
# Builds on top of the general-purpose testenv image. Adds Portage
# configuration and zed's build dependencies (Rust, LLVM, system libs).
#
# This image is intentionally scoped to zed build testing. It:
#   - Masks app-editors/zed from the main gentoo tree so our ebuild is
#     always used
#   - Disables Portage sandbox features that do not work in rootless
#     Podman containers
#   - Pre-installs all build dependencies so zed builds do not need
#     network access at runtime
#
# Build from repo root:
#   podman build -t adaptive-overlay-testenv-rust:local \
#       -f containers/testenv-rust/Containerfile .
#
# Note: The dependency list in the final RUN emerge was determined by
# running `emerge --pretend app-editors/zed::adaptive-overlay` inside
# this container after the Portage configuration was in place. If the
# ebuild's dependencies change, rebuild with --no-cache and re-verify.

FROM localhost/adaptive-overlay-testenv:local

# -----------------------------------------------------------------------
# Portage: disable sandbox features that fail in rootless containers
# -----------------------------------------------------------------------
RUN mkdir -p /etc/portage && \
    echo 'FEATURES="-ipc-sandbox -network-sandbox -pid-sandbox -usersandbox"' \
    >> /etc/portage/make.conf

# -----------------------------------------------------------------------
# Portage: USE flags required by zed's dependencies
# -----------------------------------------------------------------------
RUN mkdir -p /etc/portage/package.use && \
    printf '# Required by app-editors/zed\n' \
        > /etc/portage/package.use/zed && \
    printf '>=media-libs/vulkan-loader-1.4.0 X\n' \
        >> /etc/portage/package.use/zed && \
    printf '>=x11-libs/libxkbcommon-1.0.0 X\n' \
        >> /etc/portage/package.use/zed

# -----------------------------------------------------------------------
# Portage: mask zed from the main gentoo tree so only our ebuild is used
# -----------------------------------------------------------------------
RUN mkdir -p /etc/portage/package.mask && \
    printf '# Force use of app-editors/zed from adaptive-overlay only\n' \
        > /etc/portage/package.mask/zed && \
    printf 'app-editors/zed::gentoo\n' \
        >> /etc/portage/package.mask/zed

# -----------------------------------------------------------------------
# Portage: accept ~amd64 keywords for zed and its dependencies
# -----------------------------------------------------------------------
RUN mkdir -p /etc/portage/package.accept_keywords && \
    printf '# app-editors/zed is keyworded ~amd64\n' \
        > /etc/portage/package.accept_keywords/zed && \
    printf 'app-editors/zed::adaptive-overlay ~amd64\n' \
        >> /etc/portage/package.accept_keywords/zed && \
    printf '# rust-bin: accept ~amd64 for minimum required version\n' \
        >> /etc/portage/package.accept_keywords/zed && \
    printf '=dev-lang/rust-bin-1.93.0 ~amd64\n' \
        >> /etc/portage/package.accept_keywords/zed

# -----------------------------------------------------------------------
# Install all build dependencies for app-editors/zed except zed itself.
# zed is bind-mounted from the overlay at runtime.
#
# This list was generated by running:
#   emerge --pretend --verbose --tree app-editors/zed::adaptive-overlay
# inside this container (after the Portage config above was in place).
# If the ebuild's dependencies change, rebuild with --no-cache and
# re-run the --pretend to get the updated list.
#
# Verified against: app-editors/zed-0.227.1::adaptive-overlay
# -----------------------------------------------------------------------
RUN emerge --oneshot --quiet-build \
    dev-util/desktop-file-utils \
    x11-misc/shared-mime-info \
    dev-libs/glib \
    llvm-core/clang:21 \
    llvm-runtimes/clang-runtime:21 \
    llvm-runtimes/compiler-rt-sanitizers:21 \
    llvm-runtimes/compiler-rt:21 \
    llvm-core/clang-toolchain-symlinks:21 \
    llvm-core/llvm:21 \
    llvm-core/llvm-toolchain-symlinks:21 \
    llvm-core/llvmgold \
    media-fonts/dejavu \
    dev-lang/rust-bin:1.93.0 \
    sys-apps/lsb-release \
    app-eselect/eselect-rust \
    virtual/libelf \
    dev-python/docutils \
    dev-python/pillow \
    media-libs/libjpeg-turbo \
    dev-lang/nasm \
    media-libs/vulkan-loader \
    x11-libs/libXrandr \
    x11-libs/libXrender \
    x11-libs/libXext \
    x11-libs/libxkbcommon \
    x11-libs/libX11 \
    x11-misc/compose-tables \
    x11-libs/libxcb \
    x11-libs/libXdmcp \
    media-libs/fontconfig \
    virtual/ttf-fonts \
    media-fonts/liberation-fonts \
    x11-base/xcb-proto \
    x11-libs/libXau \
    dev-libs/wayland-protocols \
    dev-libs/wayland \
    dev-libs/libgit2 \
    x11-libs/xtrans \
    media-libs/freetype \
    dev-util/wayland-scanner \
    net-libs/libssh2 \
    media-libs/libpng \
    sys-libs/binutils-libs \
    dev-libs/protobuf \
    app-misc/jq \
    dev-libs/oniguruma \
    net-libs/llhttp \
    dev-cpp/abseil-cpp \
    media-libs/alsa-lib \
    media-libs/alsa-ucm-conf \
    media-libs/alsa-topology-conf \
    app-eselect/eselect-fontconfig \
    x11-misc/xkeyboard-config \
    dev-python/pybind11 \
    dev-python/scikit-build-core \
    dev-python/pyproject-metadata \
    dev-cpp/eigen \
    dev-python/olefile \
    dev-python/pygments \
    app-text/xmlto \
    llvm-runtimes/clang-unwindlib-config:21 \
    llvm-runtimes/openmp \
    llvm-core/llvm-common \
    dev-util/vulkan-tools \
    dev-libs/mimalloc \
    llvm-runtimes/clang-stdlib-config:21 \
    llvm-runtimes/clang-rtlib-config:21 \
    llvm-core/clang-linker-config:21 \
    dev-util/vulkan-headers \
    x11-base/xorg-proto \
    app-arch/zstd \
    dev-db/sqlite \
    dev-libs/openssl \
    net-misc/curl
